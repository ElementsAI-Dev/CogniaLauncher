# Reference: https://help.github.com/articles/ignoring-files/

# Dependencies and package managers
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs and framework caches
/.next/
/out/
/build
.swc/
*.tsbuildinfo
next-env.d.ts

# Test outputs and coverage reports
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
junit.xml
test-results.json
*.test.js.snap
*.test.ts.snap
*.test.tsx.snap

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env*

# Deployment and hosting
.vercel

# System files and local artifacts
.DS_Store
Thumbs.db
nul
*.pem

# AI and local assistant metadata
.ace-tool/
.claude/
.serena/
.windsurfrules

# Tauri debug artifacts
src-tauri/check_output.txt
src-tauri/target-*/

# Plugin SDK build artifacts
plugin-sdk/**/target/
plugin-sdk/**/plugin.wasm
plugin-sdk-ts/**/node_modules/
plugin-sdk-ts/**/dist/
plugin-sdk-ts/**/*.wasm

# Built-in plugin workspace build artifacts
plugins/**/target/
plugins/**/node_modules/
plugins/**/dist/

# OpenSpec workspace artifacts
openspec
