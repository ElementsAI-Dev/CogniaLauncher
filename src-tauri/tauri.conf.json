{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CogniaLauncher",
  "version": "0.1.0",
  "identifier": "com.cognia.launcher",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "CogniaLauncher",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    },
    "cli": {
      "description": "CogniaLauncher - Unified Environment and Package Manager",
      "args": [
        {
          "name": "json",
          "description": "Output in JSON format for scripting"
        },
        {
          "name": "minimized",
          "description": "Start minimized to system tray"
        }
      ],
      "subcommands": {
        "search": {
          "description": "Search packages across providers",
          "args": [
            {
              "name": "query",
              "index": 1,
              "takesValue": true,
              "description": "Search query string"
            },
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Filter by provider ID"
            },
            {
              "name": "limit",
              "short": "l",
              "takesValue": true,
              "description": "Maximum number of results (default: 20)"
            }
          ]
        },
        "install": {
          "description": "Install one or more packages",
          "args": [
            {
              "name": "packages",
              "index": 1,
              "takesValue": true,
              "multiple": true,
              "description": "Packages to install (e.g. lodash express@4)"
            },
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Specify provider ID"
            },
            {
              "name": "force",
              "short": "f",
              "description": "Force reinstall"
            },
            {
              "name": "continue-on-error",
              "description": "Continue processing remaining packages when one install fails"
            }
          ]
        },
        "uninstall": {
          "description": "Uninstall one or more packages",
          "args": [
            {
              "name": "packages",
              "index": 1,
              "takesValue": true,
              "multiple": true,
              "description": "Packages to uninstall"
            },
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Specify provider ID"
            },
            {
              "name": "force",
              "short": "f",
              "description": "Force uninstall"
            },
            {
              "name": "continue-on-error",
              "description": "Continue processing remaining packages when one uninstall fails"
            }
          ]
        },
        "list": {
          "description": "List installed packages",
          "args": [
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Filter by provider ID"
            },
            {
              "name": "outdated",
              "description": "Show only outdated packages"
            }
          ]
        },
        "update": {
          "description": "Update packages",
          "args": [
            {
              "name": "packages",
              "index": 1,
              "takesValue": true,
              "multiple": true,
              "description": "Packages to update (omit for --all)"
            },
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Filter by provider ID"
            },
            {
              "name": "all",
              "short": "a",
              "description": "Update all outdated packages"
            },
            {
              "name": "continue-on-error",
              "description": "Continue checking other providers when one update check fails"
            }
          ]
        },
        "info": {
          "description": "Show detailed package information",
          "args": [
            {
              "name": "package",
              "index": 1,
              "takesValue": true,
              "description": "Package name"
            },
            {
              "name": "provider",
              "short": "p",
              "takesValue": true,
              "description": "Specify provider ID"
            }
          ]
        },
        "env": {
          "description": "Manage development environment versions",
          "subcommands": {
            "list": {
              "description": "List installed environment versions",
              "args": [
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Filter by environment type (node, python, rust, ...)"
                }
              ]
            },
            "install": {
              "description": "Install an environment version",
              "args": [
                {
                  "name": "version",
                  "index": 1,
                  "takesValue": true,
                  "description": "Version to install"
                },
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Environment type (required)"
                },
                {
                  "name": "provider",
                  "short": "p",
                  "takesValue": true,
                  "description": "Specific provider ID"
                }
              ]
            },
            "use": {
              "description": "Set active environment version",
              "args": [
                {
                  "name": "version",
                  "index": 1,
                  "takesValue": true,
                  "description": "Version to activate"
                },
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Environment type (required)"
                },
                {
                  "name": "local",
                  "takesValue": true,
                  "description": "Set for project directory instead of global"
                },
                {
                  "name": "provider",
                  "short": "p",
                  "takesValue": true,
                  "description": "Specific provider ID"
                }
              ]
            },
            "detect": {
              "description": "Detect installed environments",
              "args": [
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Filter by environment type"
                },
                {
                  "name": "path",
                  "takesValue": true,
                  "description": "Start path for detection (default: current directory)"
                }
              ]
            },
            "remove": {
              "description": "Remove an installed environment version",
              "args": [
                {
                  "name": "version",
                  "index": 1,
                  "takesValue": true,
                  "description": "Version to remove"
                },
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Environment type (required)"
                },
                {
                  "name": "provider",
                  "short": "p",
                  "takesValue": true,
                  "description": "Specific provider ID"
                }
              ]
            },
            "resolve": {
              "description": "Resolve effective environment version and source",
              "args": [
                {
                  "name": "type",
                  "short": "t",
                  "takesValue": true,
                  "description": "Environment type (required)"
                },
                {
                  "name": "path",
                  "takesValue": true,
                  "description": "Path to resolve from (default: current directory)"
                }
              ]
            }
          }
        },
        "config": {
          "description": "View and modify configuration",
          "subcommands": {
            "get": {
              "description": "Get a configuration value",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Configuration key (e.g. appearance.theme)"
                }
              ]
            },
            "set": {
              "description": "Set a configuration value",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Configuration key"
                },
                {
                  "name": "value",
                  "index": 2,
                  "takesValue": true,
                  "description": "New value"
                }
              ]
            },
            "list": {
              "description": "List all configuration keys and values"
            },
            "reset": {
              "description": "Reset configuration to defaults"
            },
            "export": {
              "description": "Export full configuration to a TOML file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Output TOML file path"
                }
              ]
            },
            "import": {
              "description": "Import full configuration from a TOML file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input TOML file path"
                }
              ]
            }
          }
        },
        "cache": {
          "description": "Manage download and metadata cache",
          "subcommands": {
            "info": {
              "description": "Show cache statistics"
            },
            "clean": {
              "description": "Clean cache entries",
              "args": [
                {
                  "name": "all",
                  "short": "a",
                  "description": "Clean all cache entries"
                },
                {
                  "name": "expired",
                  "short": "e",
                  "description": "Clean only expired entries"
                }
              ]
            }
          }
        },
        "doctor": {
          "description": "Run system health checks",
          "args": [
            {
              "name": "type",
              "short": "t",
              "takesValue": true,
              "description": "Check specific environment type"
            },
            {
              "name": "fix",
              "takesValue": true,
              "description": "Preview or apply a remediation by remediation id"
            },
            {
              "name": "preview",
              "description": "Preview remediation without executing it"
            }
          ]
        },
        "providers": {
          "description": "List available package providers",
          "args": [
            {
              "name": "system",
              "short": "s",
              "description": "Show only system package providers"
            }
          ]
        },
        "backup": {
          "description": "Manage application backups",
          "subcommands": {
            "list": {
              "description": "List available backups"
            },
            "create": {
              "description": "Create a new backup",
              "args": [
                {
                  "name": "contents",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Backup content types"
                },
                {
                  "name": "note",
                  "takesValue": true,
                  "description": "Optional backup note"
                }
              ]
            },
            "restore": {
              "description": "Restore from a backup path",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Backup directory path"
                },
                {
                  "name": "contents",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Restore content types"
                }
              ]
            },
            "delete": {
              "description": "Delete a backup directory",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Backup directory path"
                }
              ]
            }
          }
        },
        "profiles": {
          "description": "Manage environment profiles",
          "subcommands": {
            "list": {
              "description": "List profiles"
            },
            "get": {
              "description": "Get profile details",
              "args": [
                {
                  "name": "id",
                  "index": 1,
                  "takesValue": true,
                  "description": "Profile ID"
                }
              ]
            },
            "apply": {
              "description": "Apply profile environments",
              "args": [
                {
                  "name": "id",
                  "index": 1,
                  "takesValue": true,
                  "description": "Profile ID"
                }
              ]
            },
            "export": {
              "description": "Export profile JSON",
              "args": [
                {
                  "name": "id",
                  "index": 1,
                  "takesValue": true,
                  "description": "Profile ID"
                },
                {
                  "name": "out",
                  "takesValue": true,
                  "description": "Optional output file path"
                }
              ]
            },
            "import": {
              "description": "Import profile JSON from file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input JSON file path"
                }
              ]
            },
            "create-from-current": {
              "description": "Create profile from current environment",
              "args": [
                {
                  "name": "name",
                  "index": 1,
                  "takesValue": true,
                  "description": "Profile name"
                }
              ]
            }
          }
        },
        "envvar": {
          "description": "Manage environment variables",
          "subcommands": {
            "list": {
              "description": "List process environment variables"
            },
            "get": {
              "description": "Get environment variable value",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "set": {
              "description": "Set environment variable value",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "value",
                  "index": 2,
                  "takesValue": true,
                  "description": "Environment variable value"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "remove": {
              "description": "Remove environment variable",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "list-persistent": {
              "description": "List persistent environment variables",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: user|system"
                }
              ]
            },
            "list-persistent-typed": {
              "description": "List persistent variables with type metadata",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: user|system"
                }
              ]
            },
            "set-persistent": {
              "description": "Set persistent environment variable",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "value",
                  "index": 2,
                  "takesValue": true,
                  "description": "Environment variable value"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: user|system"
                }
              ]
            },
            "remove-persistent": {
              "description": "Remove persistent environment variable",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: user|system"
                }
              ]
            },
            "get-path": {
              "description": "Get PATH entries by scope",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "add-path": {
              "description": "Add a PATH entry",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "PATH entry value"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                },
                {
                  "name": "position",
                  "takesValue": true,
                  "description": "Optional insertion index"
                }
              ]
            },
            "remove-path": {
              "description": "Remove a PATH entry",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "PATH entry value"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "reorder-path": {
              "description": "Replace PATH entries with explicit order",
              "args": [
                {
                  "name": "entries",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Ordered PATH entries"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "deduplicate-path": {
              "description": "Deduplicate PATH entries",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "detect-conflicts": {
              "description": "Detect user/system variable conflicts"
            },
            "list-shell-profiles": {
              "description": "List detected shell profile files"
            },
            "read-shell-profile": {
              "description": "Read shell profile content",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Profile file path"
                }
              ]
            },
            "expand-path": {
              "description": "Expand env references in path text",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input path text"
                }
              ]
            },
            "export": {
              "description": "Export environment variables to file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Output file path"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                },
                {
                  "name": "format",
                  "takesValue": true,
                  "description": "Format: dotenv|shell|fish|powershell|nushell"
                }
              ]
            },
            "import": {
              "description": "Import environment variables from file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input file path"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "preview-import": {
              "description": "Preview environment variable import from file",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input file path"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "apply-import": {
              "description": "Apply environment variable import using preview fingerprint",
              "args": [
                {
                  "name": "file",
                  "index": 1,
                  "takesValue": true,
                  "description": "Input file path"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                },
                {
                  "name": "fingerprint",
                  "takesValue": true,
                  "description": "Preview fingerprint"
                }
              ]
            },
            "preview-path-repair": {
              "description": "Preview PATH repair for duplicate or missing entries",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "apply-path-repair": {
              "description": "Apply PATH repair using preview fingerprint",
              "args": [
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                },
                {
                  "name": "fingerprint",
                  "takesValue": true,
                  "description": "Preview fingerprint"
                }
              ]
            },
            "resolve-conflict": {
              "description": "Resolve an environment variable conflict by copying one scope value to another",
              "args": [
                {
                  "name": "key",
                  "index": 1,
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "source-scope",
                  "takesValue": true,
                  "description": "Source scope: process|user|system"
                },
                {
                  "name": "target-scope",
                  "takesValue": true,
                  "description": "Target scope: process|user|system"
                }
              ]
            },
            "shell-guidance": {
              "description": "Generate shell-specific follow-up guidance",
              "args": [
                {
                  "name": "key",
                  "takesValue": true,
                  "description": "Environment variable key"
                },
                {
                  "name": "value",
                  "takesValue": true,
                  "description": "Environment variable value"
                },
                {
                  "name": "entries",
                  "takesValue": true,
                  "multiple": true,
                  "description": "PATH entries to render as guidance"
                },
                {
                  "name": "auto-applied-shell",
                  "takesValue": true,
                  "description": "Shell id already updated automatically"
                }
              ]
            },
            "snapshot-list": {
              "description": "List envvar recovery snapshots"
            },
            "snapshot-create": {
              "description": "Create an envvar recovery snapshot",
              "args": [
                {
                  "name": "scopes",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Scopes to capture: user|system|process"
                },
                {
                  "name": "mode",
                  "takesValue": true,
                  "description": "Snapshot mode: manual|automatic"
                },
                {
                  "name": "source-action",
                  "takesValue": true,
                  "description": "Optional source action label"
                },
                {
                  "name": "note",
                  "takesValue": true,
                  "description": "Optional snapshot note"
                }
              ]
            },
            "snapshot-protection": {
              "description": "Preview backup protection state for a risky envvar action",
              "args": [
                {
                  "name": "action",
                  "index": 1,
                  "takesValue": true,
                  "description": "Canonical risky action id (for example: persistent_set, persistent_remove, import_apply, path_repair_apply, conflict_resolve)"
                },
                {
                  "name": "scope",
                  "takesValue": true,
                  "description": "Scope: process|user|system"
                }
              ]
            },
            "snapshot-preview": {
              "description": "Preview restore diff for an envvar snapshot",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Snapshot path"
                },
                {
                  "name": "fingerprint",
                  "takesValue": true,
                  "description": "Preview fingerprint returned by snapshot-preview"
                },
                {
                  "name": "scopes",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Optional scopes to preview; omit to preview all snapshot scopes"
                }
              ]
            },
            "snapshot-restore": {
              "description": "Restore envvar state from a snapshot",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Snapshot path"
                },
                {
                  "name": "scopes",
                  "takesValue": true,
                  "multiple": true,
                  "description": "Optional scopes to restore; omit to restore all snapshot scopes"
                }
              ]
            },
            "snapshot-delete": {
              "description": "Delete an envvar snapshot",
              "args": [
                {
                  "name": "path",
                  "index": 1,
                  "takesValue": true,
                  "description": "Snapshot path"
                }
              ]
            }
          }
        },
        "log": {
          "description": "Manage application logs",
          "subcommands": {
            "list": {
              "description": "List log files"
            },
            "export": {
              "description": "Export log entries",
              "args": [
                {
                  "name": "file",
                  "takesValue": true,
                  "description": "Source log file name"
                },
                {
                  "name": "out",
                  "takesValue": true,
                  "description": "Optional output file path"
                },
                {
                  "name": "format",
                  "takesValue": true,
                  "description": "Export format: txt|json"
                },
