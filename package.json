{
  "name": "cognia-launcher",
  "version": "0.1.0",
  "description": "Cross-platform environment and package manager",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "docs:validate": "node scripts/docs/validate-docs.mjs",
    "docs:validate:warn": "node scripts/docs/validate-docs.mjs --mode=warn",
    "git:validate": "node scripts/git/validate-git-integration.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "node scripts/run-jest-coverage.mjs",
    "test:git:coverage": "jest --config jest.git.config.ts app/git/page.test.tsx components/git hooks/git/use-git.test.ts hooks/git/use-git-advanced.test.ts hooks/git/use-git-lfs.test.ts lib/git/operation-orchestrator.test.ts scripts/git/validate-git-integration.test.js --coverage --runInBand",
    "test:settings": "jest --config jest.settings.config.ts app/settings/page.test.tsx app/settings/loading.test.tsx components/settings hooks/settings/use-settings.test.ts lib/settings lib/stores/settings.test.ts --runInBand",
    "test:settings:coverage": "jest --config jest.settings.config.ts app/settings/page.test.tsx app/settings/loading.test.tsx components/settings hooks/settings/use-settings.test.ts lib/settings lib/stores/settings.test.ts --coverage --runInBand",
    "test:dashboard": "jest --config jest.dashboard.config.ts app/page.test.tsx components/dashboard hooks/dashboard/use-dashboard-insights.test.ts hooks/dashboard/use-dashboard-search.test.ts lib/stores/dashboard.test.ts --runInBand",
    "test:dashboard:coverage": "jest --config jest.dashboard.config.ts app/page.test.tsx components/dashboard hooks/dashboard/use-dashboard-insights.test.ts hooks/dashboard/use-dashboard-search.test.ts lib/stores/dashboard.test.ts --coverage --runInBand",
    "test:docs": "jest --config jest.docs.config.ts --runInBand",
    "test:docs:coverage": "jest --config jest.docs.config.ts --coverage --runInBand",
    "test:environments": "jest --config jest.environments.config.ts app/environments components/environments hooks/environments/use-environments.test.ts hooks/environments/use-environment-detection.test.ts hooks/environments/use-environment-workflow.test.ts lib/environment-detection.test.ts lib/environment-workflow.test.ts lib/stores/environment.test.ts --runInBand",
    "test:environments:coverage": "jest --config jest.environments.config.ts app/environments components/environments hooks/environments/use-environments.test.ts hooks/environments/use-environment-detection.test.ts hooks/environments/use-environment-workflow.test.ts lib/environment-detection.test.ts lib/environment-workflow.test.ts lib/stores/environment.test.ts --coverage --runInBand",
    "test:lib": "jest lib/ --runInBand",
    "test:lib:coverage": "jest lib/ --coverage --runInBand --collectCoverageFrom=\"lib/**/*.{js,jsx,ts,tsx}\" --collectCoverageFrom=\"!lib/**/*.d.ts\" --collectCoverageFrom=\"!lib/**/index.ts\" --collectCoverageFrom=\"!lib/**/*.test.{js,jsx,ts,tsx}\" --collectCoverageFrom=\"!lib/**/*.spec.{js,jsx,ts,tsx}\" --collectCoverageFrom=\"!lib/tauri.ts\"",
    "test:wsl": "jest --config jest.wsl.config.ts app/wsl components/wsl hooks/wsl/use-wsl.test.ts hooks/wsl/use-wsl-information.test.ts hooks/wsl/use-wsl-status.test.ts lib/wsl lib/wsl.test.ts lib/stores/wsl.test.ts --runInBand",
    "test:wsl:coverage": "jest --config jest.wsl.config.ts app/wsl components/wsl hooks/wsl/use-wsl.test.ts hooks/wsl/use-wsl-information.test.ts hooks/wsl/use-wsl-status.test.ts lib/wsl lib/wsl.test.ts lib/stores/wsl.test.ts --coverage --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "plugins:build": "node scripts/plugins/build-builtins.mjs",
    "plugins:checksums": "node scripts/plugins/update-checksums.mjs",
    "plugins:validate": "node scripts/plugins/validate-suite.mjs --skip-build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-layout-effect": "1.1.1",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-cli": "^2.4.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-positioner": "^2.3.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.55.1",
    "next": "16.0.10",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.0.0",
    "graceful-fs": "4.2.11",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^16.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "plugin-sdk-ts",
    "plugin-sdk-ts/examples/*",
    "plugins/typescript/*"
  ]
}
