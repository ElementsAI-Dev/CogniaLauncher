    "setup:toolchain": "node scripts/build.mjs --setup-only"
  },
  "dependencies": {
    "@cognia/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@extism/js-pdk": "^1.1.1",
    "esbuild": "^0.20.0"
  }
}
